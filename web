function fmtCard(el) {
  let v = el.value.replace(/\D/g,'').substring(0,16);
  el.value = v.replace(/(.{4})/g,'$1 ').trim();
}
function fmtExp(el) {
  let v = el.value.replace(/\D/g,'').substring(0,4);
  if(v.length>2) v=v.substring(0,2)+'/'+v.substring(2);
  el.value=v;
}

// ══════════════════════════════════════
// ADMIN
// ══════════════════════════════════════
function openAdmin() {
  if (!currentUser || currentUser.role!=='admin') {
    openOv('authModal');
    showToast('Acceso solo para administradores 🔒','error');
    return;
  }
  renderAdminDashboard();
  renderProductsTable();
  renderOrdersTable();
  renderUsersTable();
  document.getElementById('adminPanel').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeAdmin() {
  document.getElementById('adminPanel').classList.remove('open');
  document.body.style.overflow='';
}
function adminTab(tab, btn) {
  document.querySelectorAll('.admin-panel-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.anav').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  btn.classList.add('active');
  if(tab==='dashboard') renderAdminDashboard();
  if(tab==='products') renderProductsTable();
  if(tab==='orders') renderOrdersTable();
  if(tab==='users') renderUsersTable();
}
function renderAdminDashboard() {
  const totalSales = orders.reduce((a,o)=>a+o.total,0);
  document.getElementById('statOrders').textContent = orders.length;
  document.getElementById('statSales').textContent = '$'+totalSales.toLocaleString('es-CL');
  document.getElementById('statUsers').textContent = users.length;
  document.getElementById('statProducts').textContent = products.length;
  const tbody = document.getElementById('dashOrdersBody');
  if (!orders.length) { tbody.innerHTML='<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:24px">No hay pedidos aún</td></tr>'; return; }
  tbody.innerHTML = orders.slice(-8).reverse().map(o=>`
    <tr>
      <td><strong>#${o.id}</strong></td>
      <td>${o.client}</td>
      <td style="color:var(--pink);font-weight:700">$${o.total.toLocaleString('es-CL')}</td>
      <td><span class="badge-tag ${o.status}">${o.status}</span></td>
      <td style="color:var(--muted)">${o.date}</td>
    </tr>`).join('');
}
function renderProductsTable() {
  document.getElementById('productCount').textContent = products.length + ' productos';
  document.getElementById('productsTableBody').innerHTML = products.map(p=>`
    <tr>
      <td><img class="admin-img-thumb" src="${p.img}" alt=""></td>
      <td><input class="edit-input wide" value="${p.name}" onchange="editProduct(${p.id},'name',this.value)"></td>
      <td>
        <select class="status-select" onchange="editProduct(${p.id},'cat',this.value)">
          ${['jeans-hombre','jeans-mujer','poleron','polera','chaqueta','gorro','jockey','accesorio'].map(c=>`<option value="${c}" ${p.cat===c?'selected':''}>${catLabel(c)}</option>`).join('')}
        </select>
      </td>
      <td><input class="edit-input" type="number" value="${p.price}" onchange="editProduct(${p.id},'price',parseInt(this.value))"></td>
      <td>
        <select class="status-select" onchange="editProduct(${p.id},'badge',this.value)">
          <option value="" ${p.badge===''?'selected':''}>Sin badge</option>
          <option value="new" ${p.badge==='new'?'selected':''}>NUEVO</option>
          <option value="top" ${p.badge==='top'?'selected':''}>TOP</option>
          <option value="sale" ${p.badge==='sale'?'selected':''}>OFERTA</option>
        </select>
      </td>
      <td><button class="ab danger" onclick="deleteProduct(${p.id})">Eliminar</button></td>
    </tr>`).join('');
}
function editProduct(id, field, val) {
  const p = products.find(x=>x.id===id);
  if (p) { p[field]=val; renderProducts(document.querySelector('.tab.active')?.textContent.toLowerCase().includes('todo') ? 'all' : p.cat); showToast('Producto actualizado ✓','success'); }
}
function deleteProduct(id) {
  if (!confirm('¿Eliminar este producto?')) return;
  products = products.filter(p=>p.id!==id);
  renderProductsTable();
  renderProducts('all');
  showToast('Producto eliminado','info');
}
function toggleAddForm() {
  const f = document.getElementById('addProductForm');
  f.style.display = f.style.display==='none' ? '' : 'none';
}
function addProduct() {
  const name = document.getElementById('newName').value.trim();
  const cat = document.getElementById('newCat').value;
  const price = parseInt(document.getElementById('newPrice').value)||0;
  const badge = document.getElementById('newBadge').value;
  const img = document.getElementById('newImg').value.trim();
  const desc = document.getElementById('newDesc').value.trim();
  const sizesRaw = document.getElementById('newSizes').value.trim();
  if (!name||!price||!img) { showToast('Completa nombre, precio e imagen','error'); return; }
  const sizes = sizesRaw ? sizesRaw.split(',').map(s=>s.trim()).filter(Boolean) : ['Talla Única'];
  const newId = Math.max(...products.map(p=>p.id))+1;
  products.push({id:newId,cat,name,price,badge,img,desc,sizes});
  toggleAddForm();
  renderProductsTable();
  renderProducts('all');
  showToast('Producto agregado ✓','success');
  ['newName','newPrice','newImg','newDesc','newSizes'].forEach(id=>{ document.getElementById(id).value=''; });
}
function renderOrdersTable() {
  const tbody = document.getElementById('ordersTableBody');
  if (!orders.length) { tbody.innerHTML='<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:24px">No hay pedidos registrados</td></tr>'; return; }
  tbody.innerHTML = orders.map((o,idx)=>`
    <tr>
      <td><strong>#${o.id}</strong></td>
      <td>${o.client}<br><span style="font-size:.72rem;color:var(--muted)">${o.email}</span></td>
      <td style="font-size:.76rem;color:var(--muted)">${o.items.map(i=>i.name.split(' ').slice(0,3).join(' ')).join(', ')}</td>
      <td style="color:var(--pink);font-weight:700">$${o.total.toLocaleString('es-CL')}</td>
      <td>
        <select class="status-select ${o.status}" onchange="changeOrderStatus(${idx},this)">
          <option value="pendiente" ${o.status==='pendiente'?'selected':''}>Pendiente</option>
          <option value="procesando" ${o.status==='procesando'?'selected':''}>Procesando</option>
          <option value="enviado" ${o.status==='enviado'?'selected':''}>Enviado</option>
          <option value="entregado" ${o.status==='entregado'?'selected':''}>Entregado</option>
          <option value="cancelado" ${o.status==='cancelado'?'selected':''}>Cancelado</option>
        </select>
      </td>
      <td style="color:var(--muted)">${o.date}</td>
    </tr>`).join('');
}
function changeOrderStatus(idx, sel) {
  orders[idx].status = sel.value;
  sel.className = 'status-select ' + sel.value;
  showToast('Estado actualizado ✓','success');
  renderAdminDashboard();
}
function renderUsersTable() {
  document.getElementById('usersTableBody').innerHTML = users.map(u=>`
    <tr>
      <td>${u.name} ${u.last}</td>
      <td style="color:var(--muted)">${u.email}</td>
      <td><span class="role-tag ${u.role}">${u.role.toUpperCase()}</span></td>
      <td>${u.orders.length}</td>
      <td style="color:var(--muted)">${u.date}</td>
      <td>
        ${u.role!=='admin'?`<button class="ab green" onclick="promoteUser(${u.id})">Hacer admin</button>`:'<span style="color:var(--muted);font-size:.76rem">—</span>'}
      </td>
    </tr>`).join('');
}
function promoteUser(id) {
  const u = users.find(x=>x.id===id);
  if (u && confirm(`¿Hacer admin a ${u.name}?`)) {
    u.role='admin';
    saveUsers();
    renderUsersTable();
    showToast(`${u.name} ahora es admin 🔑`,'success');
  }
}

// ══════════════════════════════════════
// TOAST
// ══════════════════════════════════════
let toastTimer;
function showToast(msg, type='info') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>{ t.classList.remove('show'); }, 3200);
}

// ══════════════════════════════════════
// ESC & SCROLL FADE
// ══════════════════════════════════════
document.addEventListener('keydown', e=>{
  if (e.key==='Escape') {
    closeModalDirect();
    ['authModal','profileModal','checkoutModal'].forEach(id=>closeOv(id));
    if(document.getElementById('cartDrw').classList.contains('open')) toggleCart();
  }
});
const obs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('vis');obs.unobserve(e.target);} });
},{threshold:.08});
document.querySelectorAll('.fi-anim').forEach(el=>obs.observe(el));

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
renderProducts('all');
</script>
</body>
</html>
