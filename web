  if (user.role==='admin') { setTimeout(()=>{ if(confirm('¿Abrir el panel de administración?')) openAdmin(); }, 400); }
}
function doRegister() {
  const name = document.getElementById('regName').value.trim();
  const last = document.getElementById('regLast').value.trim();
  const email = document.getElementById('regEmail').value.trim().toLowerCase();
  const pass = document.getElementById('regPass').value;
  const pass2 = document.getElementById('regPass2').value;
  const errEl = document.getElementById('regError');
  errEl.classList.remove('show');
  document.getElementById('regSuccess').classList.remove('show');

  // Validaciones
  if (!name || !email || !pass) { errEl.textContent='Completa todos los campos obligatorios.'; errEl.classList.add('show'); return; }
  if (!isValidEmail(email)) { errEl.textContent='Ingresa un correo electrónico válido.'; errEl.classList.add('show'); return; }
  if (pass !== pass2) { errEl.textContent='Las contraseñas no coinciden.'; errEl.classList.add('show'); return; }
  if (pass.length < 6) { errEl.textContent='La contraseña debe tener al menos 6 caracteres.'; errEl.classList.add('show'); return; }
  if (users.find(u => u.email.toLowerCase()===email)) { errEl.textContent='Ese correo ya está registrado.'; errEl.classList.add('show'); return; }

  const newUser = {id: Date.now(), name, last, email, passHash: hashPass(pass), role:'cliente', date: new Date().toISOString().split('T')[0], orders:[]};
  users.push(newUser);
  saveUsers(); // ← persiste en localStorage
