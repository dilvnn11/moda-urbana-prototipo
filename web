<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MODA URBANO | Ropa Urbana Hombre & Mujer</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0d0d0d;--surface:#111;--s2:#1a1a1a;--pink:#ff005c;--cyan:#00e5ff;--green:#00b37e;--text:#f0f0f0;--muted:#777;--border:rgba(255,255,255,0.07);--r:14px}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.5;overflow-x:hidden}

/* ANNOUNCEMENT */
.ann{background:var(--pink);color:#fff;padding:9px 0;font-size:.78rem;font-weight:700;letter-spacing:2px;overflow:hidden;white-space:nowrap}
.ann span{display:inline-block;animation:marquee 24s linear infinite}
@keyframes marquee{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}

/* HEADER */
header{position:sticky;top:0;z-index:900;background:rgba(13,13,13,.97);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.hdr{max-width:1380px;margin:0 auto;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 24px;height:66px}
.nav-l,.nav-r{display:flex;align-items:center;gap:4px}
.nav-r{justify-content:flex-end}
.logo{text-align:center;font-family:'Space Grotesk',sans-serif;font-size:1.55rem;font-weight:700;color:#fff;text-decoration:none;letter-spacing:-.5px}
.logo em{background:linear-gradient(90deg,var(--pink),var(--cyan));-webkit-background-clip:text;color:transparent;font-style:normal}
.nl{color:#bbb;text-decoration:none;font-size:.78rem;font-weight:600;letter-spacing:.4px;padding:7px 10px;border-radius:8px;transition:color .2s,background .2s;white-space:nowrap;cursor:pointer;border:none;background:none}
.nl:hover{color:#fff;background:rgba(255,255,255,.06)}
.nl.hot{color:var(--pink)}
.dd{position:relative}
.ddmenu{position:absolute;top:calc(100% + 6px);left:0;background:#161616;border:1px solid var(--border);border-radius:12px;padding:6px 0;min-width:190px;opacity:0;pointer-events:none;transform:translateY(-6px);transition:opacity .2s,transform .2s;box-shadow:0 20px 40px rgba(0,0,0,.7);z-index:999}
.dd:hover .ddmenu{opacity:1;pointer-events:all;transform:translateY(0)}
.ddmenu a{display:block;color:#aaa;text-decoration:none;font-size:.8rem;font-weight:500;padding:8px 16px;transition:color .15s,background .15s}
.ddmenu a:hover{color:#fff;background:rgba(255,255,255,.05)}
.ddlabel{font-size:.65rem;font-weight:800;color:var(--pink);letter-spacing:1.5px;padding:8px 16px 2px;text-transform:uppercase}
.ddgrp{border-top:1px solid var(--border);padding-top:4px;margin-top:4px}
.ddgrp:first-child{border:none;margin:0}
.cartbtn{background:var(--pink);color:#fff;border:none;cursor:pointer;font-size:.78rem;font-weight:800;letter-spacing:.5px;padding:9px 18px;border-radius:50px;display:flex;align-items:center;gap:7px;transition:transform .2s,background .2s}
.cartbtn:hover{transform:scale(1.04);background:#d40049}
.cc{background:#fff;color:var(--pink);width:18px;height:18px;border-radius:50%;font-size:.68rem;font-weight:900;display:flex;align-items:center;justify-content:center}
.iconbtn{background:none;border:none;cursor:pointer;color:#bbb;font-size:1rem;padding:8px;border-radius:8px;transition:color .2s,background .2s}
.iconbtn:hover{color:#fff;background:rgba(255,255,255,.06)}
.auth-btn{background:rgba(255,255,255,.07);border:1px solid var(--border);color:#ccc;font-size:.76rem;font-weight:600;padding:7px 14px;border-radius:50px;cursor:pointer;transition:all .2s;white-space:nowrap}
.auth-btn:hover{background:rgba(255,255,255,.12);color:#fff}
.auth-btn.logged{background:rgba(0,229,255,.08);border-color:rgba(0,229,255,.2);color:var(--cyan)}

/* HERO */
.hero{position:relative;min-height:90vh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden}
.hbg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=2000&q=80') center/cover no-repeat}
.hbg::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(13,13,13,.35) 0%,rgba(13,13,13,.88) 100%)}
.hcont{position:relative;z-index:2;padding:0 20px}
.eyebrow{display:inline-block;background:var(--pink);color:#fff;font-size:.7rem;font-weight:800;letter-spacing:3px;padding:5px 16px;border-radius:50px;margin-bottom:22px}
.hero h1{font-family:'Space Grotesk',sans-serif;font-size:clamp(3rem,9vw,8rem);font-weight:700;line-height:.93;letter-spacing:-2px;margin-bottom:22px;color:#fff}
.hero h1 span{background:linear-gradient(90deg,var(--pink),var(--cyan));-webkit-background-clip:text;color:transparent}
.hsub{font-size:1rem;color:rgba(255,255,255,.6);max-width:540px;margin:0 auto 34px}
.hbtns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn-w{background:#fff;color:#000;padding:14px 38px;border-radius:50px;font-size:.88rem;font-weight:800;letter-spacing:1px;border:none;cursor:pointer;transition:all .25s;text-decoration:none;display:inline-block}
.btn-w:hover{background:var(--pink);color:#fff;transform:scale(1.04)}
.btn-o{background:transparent;color:#fff;padding:14px 38px;border-radius:50px;font-size:.88rem;font-weight:700;letter-spacing:1px;border:1.5px solid rgba(255,255,255,.3);cursor:pointer;transition:all .25s;text-decoration:none;display:inline-block}
.btn-o:hover{border-color:#fff;background:rgba(255,255,255,.08)}

/* TRUST */
.trust{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.trust-i{max-width:1380px;margin:0 auto;display:flex;justify-content:center;align-items:center;gap:44px;padding:16px 24px;flex-wrap:wrap}
.ti{display:flex;align-items:center;gap:10px;font-size:.8rem;font-weight:600;color:#bbb}
.ti strong{color:#fff}

/* WRAP */
.wrap{max-width:1380px;margin:0 auto;padding:70px 24px}
.stitle{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:700;letter-spacing:-.5px;margin-bottom:36px}
.stitle span{color:var(--pink)}

/* QUICK CATS */
.qcats{display:flex;gap:14px;overflow-x:auto;padding-bottom:6px;scrollbar-width:none}
.qcats::-webkit-scrollbar{display:none}
.qcat{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:9px;cursor:pointer;text-decoration:none}
.qcimg{width:104px;height:104px;border-radius:50%;overflow:hidden;border:2.5px solid var(--border);transition:border-color .2s;background-size:cover;background-position:center}
.qcat:hover .qcimg{border-color:var(--pink)}
.qcname{font-size:.74rem;font-weight:600;color:#bbb;text-align:center}

/* GENDER */
.ggrid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.gcard{position:relative;border-radius:var(--r);overflow:hidden;aspect-ratio:3/4;display:flex;align-items:flex-end;cursor:pointer;text-decoration:none}
.gcard img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .5s}
.gcard:hover img{transform:scale(1.05)}
.gcov{position:relative;z-index:2;width:100%;background:linear-gradient(transparent,rgba(0,0,0,.78) 60%);padding:28px 22px 22px}
.glabel{font-family:'Space Grotesk',sans-serif;font-size:1.35rem;font-weight:700;color:#fff}
.glink{display:inline-block;margin-top:7px;font-size:.76rem;font-weight:700;color:var(--pink);letter-spacing:1px}

/* TABS */
.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px}
.tab{background:var(--surface);border:1.5px solid var(--border);color:#999;padding:8px 18px;border-radius:50px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap}
.tab.active,.tab:hover{background:var(--pink);border-color:var(--pink);color:#fff}

/* PRODUCTS */
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:18px}
.pcard{background:var(--surface);border-radius:var(--r);overflow:hidden;cursor:pointer;position:relative;transition:transform .3s,box-shadow .3s;border:1px solid var(--border)}
.pcard:hover{transform:translateY(-8px);box-shadow:0 24px 48px rgba(0,0,0,.55)}
.pimgw{position:relative;aspect-ratio:3/4;overflow:hidden;background:#1c1c1c}
.pimgw img{width:100%;height:100%;object-fit:cover;transition:transform .5s;display:block}
.pcard:hover .pimgw img{transform:scale(1.07)}
.badge{position:absolute;top:11px;left:11px;color:#fff;font-size:.65rem;font-weight:800;letter-spacing:1px;padding:3px 10px;border-radius:50px}
.badge.top{background:var(--pink)}
.badge.new{background:var(--green)}
.badge.sale{background:#f59e0b}
.qadd{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.82);backdrop-filter:blur(4px);color:#fff;font-size:.76rem;font-weight:800;letter-spacing:1px;padding:12px;text-align:center;transform:translateY(100%);transition:transform .25s}
.pcard:hover .qadd{transform:translateY(0)}
.pinfo{padding:14px}
.pname{font-weight:600;font-size:.88rem;margin-bottom:5px;color:#ddd}
.pcat{font-size:.7rem;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
.pprice{color:var(--pink);font-size:1.05rem;font-weight:700}
.pprice-old{color:var(--muted);font-size:.82rem;text-decoration:line-through;margin-left:6px}

/* COLECCIONES */
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px}
.ccard{position:relative;border-radius:var(--r);overflow:hidden;aspect-ratio:4/5;cursor:pointer;text-decoration:none;display:block}
.ccard img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
.ccard:hover img{transform:scale(1.05)}
.ccbody{position:absolute;inset:0;background:linear-gradient(transparent 40%,rgba(0,0,0,.82));display:flex;flex-direction:column;justify-content:flex-end;padding:22px}
.cctitle{font-family:'Space Grotesk',sans-serif;font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:3px}
.cccta{font-size:.74rem;color:var(--pink);font-weight:700;letter-spacing:1px}

/* NEWSLETTER */
.nl-sect{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.nl-inner{max-width:520px;margin:0 auto;text-align:center;padding:66px 24px}
.nl-inner h2{font-family:'Space Grotesk',sans-serif;font-size:1.9rem;font-weight:700;margin-bottom:8px}
.nl-inner p{color:var(--muted);margin-bottom:26px;font-size:.88rem}
.nl-form{display:flex;gap:8px}
.nl-form input{flex:1;background:var(--bg);border:1.5px solid var(--border);color:#fff;border-radius:50px;padding:12px 18px;font-size:.88rem;outline:none;transition:border-color .2s}
.nl-form input:focus{border-color:var(--pink)}
.nl-form button{background:var(--pink);color:#fff;border:none;cursor:pointer;border-radius:50px;padding:12px 22px;font-weight:800;font-size:.82rem;letter-spacing:.5px;transition:background .2s;white-space:nowrap}
.nl-form button:hover{background:#d40049}

/* FOOTER */
.fi{max-width:1380px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;padding:56px 24px 36px}
.fbrand .logo{font-size:1.3rem;display:block;margin-bottom:10px}
.fbrand p{font-size:.82rem;color:var(--muted);max-width:220px;line-height:1.7}
.fcol h4{font-size:.68rem;font-weight:800;letter-spacing:2px;color:#fff;margin-bottom:14px;text-transform:uppercase}
.fcol a{display:block;color:var(--muted);text-decoration:none;font-size:.82rem;margin-bottom:9px;transition:color .2s}
.fcol a:hover{color:#fff}
.fbot{border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;padding:18px 24px;max-width:1380px;margin:0 auto;font-size:.76rem;color:var(--muted)}
.pays{display:flex;gap:6px}
.pay{background:var(--surface);border:1px solid var(--border);border-radius:5px;padding:3px 8px;font-size:.68rem;font-weight:700;color:#bbb}

/* MODAL */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1800;opacity:0;pointer-events:none;transition:opacity .3s;display:flex;align-items:center;justify-content:center;padding:20px}
.modal-ov.open{opacity:1;pointer-events:all}
.modal{background:#161616;border-radius:20px;border:1px solid var(--border);width:100%;max-width:900px;max-height:90vh;overflow-y:auto;transform:scale(.95);transition:transform .3s;display:grid;grid-template-columns:1fr 1fr}
.modal-ov.open .modal{transform:scale(1)}
.modal-img{aspect-ratio:3/4;overflow:hidden;border-radius:20px 0 0 20px}
.modal-img img{width:100%;height:100%;object-fit:cover}
.modal-body{padding:36px 32px;display:flex;flex-direction:column;gap:14px;overflow-y:auto}
.modal-close{align-self:flex-end;background:none;border:none;color:#999;font-size:1.4rem;cursor:pointer;line-height:1}
.modal-close:hover{color:#fff}
.modal-cat{font-size:.7rem;font-weight:700;letter-spacing:2px;color:var(--pink);text-transform:uppercase}
.modal-name{font-family:'Space Grotesk',sans-serif;font-size:1.6rem;font-weight:700;line-height:1.2}
.modal-price{font-size:1.5rem;font-weight:800;color:var(--pink)}
.modal-desc{font-size:.86rem;color:#aaa;line-height:1.7}
.modal-sizes{display:flex;gap:8px;flex-wrap:wrap}
.sz{border:1.5px solid var(--border);background:none;color:#ccc;padding:8px 14px;border-radius:8px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .2s}
.sz:hover,.sz.active{border-color:var(--pink);color:#fff;background:rgba(255,0,92,.1)}
.modal-add{background:var(--pink);color:#fff;border:none;cursor:pointer;padding:15px;border-radius:50px;font-size:.9rem;font-weight:800;letter-spacing:1px;transition:background .2s;width:100%}
.modal-add:hover{background:#d40049}
.modal-features{display:flex;flex-direction:column;gap:8px;border-top:1px solid var(--border);padding-top:14px}
.mf{font-size:.8rem;color:#aaa;display:flex;gap:8px;align-items:center}

/* CART DRAWER */
.cart-ov{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1999;opacity:0;pointer-events:none;transition:opacity .3s}
.cart-ov.open{opacity:1;pointer-events:all}
.cart-drw{position:fixed;top:0;right:0;bottom:0;width:440px;max-width:100%;background:#141414;border-left:1px solid var(--border);z-index:2000;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column}
.cart-drw.open{transform:translateX(0)}
.cart-hdr{display:flex;justify-content:space-between;align-items:center;padding:18px 22px;border-bottom:1px solid var(--border)}
.cart-hdr h3{font-size:.95rem;font-weight:700}
.cart-cls{background:none;border:none;color:#999;cursor:pointer;font-size:1.2rem}
.cart-empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--muted);gap:12px;font-size:.9rem}
.cart-items{flex:1;overflow-y:auto;padding:16px}
.cart-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid var(--border)}
.ci-img{width:70px;height:70px;border-radius:8px;object-fit:cover;flex-shrink:0}
.ci-info{flex:1}
.ci-name{font-size:.84rem;font-weight:600;margin-bottom:3px}
.ci-sz{font-size:.74rem;color:var(--muted);margin-bottom:6px}
.ci-bottom{display:flex;justify-content:space-between;align-items:center}
.ci-price{font-size:.9rem;font-weight:700;color:var(--pink)}
.ci-rm{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.78rem;transition:color .2s}
.ci-rm:hover{color:#ff4444}
.ci-qty{display:flex;align-items:center;gap:6px;font-size:.82rem}
.ci-qty button{background:var(--s2);border:1px solid var(--border);color:#ccc;width:22px;height:22px;border-radius:4px;cursor:pointer;font-size:.85rem;line-height:1;display:flex;align-items:center;justify-content:center;transition:background .2s}
.ci-qty button:hover{background:rgba(255,0,92,.15);border-color:var(--pink);color:#fff}

/* DISCOUNT CODE */
.discount-row{padding:10px 22px;border-top:1px solid var(--border);display:flex;gap:8px}
.discount-row input{flex:1;background:var(--bg);border:1.5px solid var(--border);color:#fff;border-radius:8px;padding:9px 14px;font-size:.8rem;outline:none;transition:border-color .2s}
.discount-row input:focus{border-color:var(--pink)}
.discount-row input::placeholder{color:var(--muted)}
.discount-row button{background:var(--s2);border:1px solid var(--border);color:#ccc;border-radius:8px;padding:9px 14px;font-size:.78rem;font-weight:700;cursor:pointer;transition:all .2s;white-space:nowrap}
.discount-row button:hover{border-color:var(--pink);color:var(--pink)}
.discount-ok{font-size:.76rem;color:var(--green);padding:0 22px 8px;font-weight:600}
.cart-foot{padding:18px 22px;border-top:1px solid var(--border)}
.cart-summary-row{display:flex;justify-content:space-between;font-size:.82rem;color:#aaa;margin-bottom:6px}
.cart-summary-row.discount{color:var(--green)}
.cart-total{display:flex;justify-content:space-between;margin-bottom:14px;font-weight:700;margin-top:8px;padding-top:8px;border-top:1px solid var(--border)}
.cart-chk{display:block;width:100%;background:var(--pink);color:#fff;border:none;cursor:pointer;padding:15px;border-radius:50px;font-size:.88rem;font-weight:800;letter-spacing:1px;transition:background .2s;text-align:center}
.cart-chk:hover{background:#d40049}
.cart-chk:disabled{background:#555;cursor:not-allowed}

/* FADE */
.fi-anim{opacity:0;transform:translateY(22px);transition:opacity .6s,transform .6s}
.fi-anim.vis{opacity:1;transform:translateY(0)}

/* ── OVERLAY SYSTEM ── */
.ov-layer{position:fixed;inset:0;z-index:3000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .3s}
.ov-layer.open{opacity:1;pointer-events:all}
.ov-layer::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,.82)}
.ov-box{position:relative;background:#161616;border:1px solid var(--border);border-radius:20px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;padding:36px;transform:scale(.95);transition:transform .3s}
.ov-layer.open .ov-box{transform:scale(1)}
.ov-close{position:absolute;top:18px;right:18px;background:none;border:none;color:#777;font-size:1.3rem;cursor:pointer;line-height:1;transition:color .2s}
.ov-close:hover{color:#fff}
.ov-title{font-family:'Space Grotesk',sans-serif;font-size:1.4rem;font-weight:700;margin-bottom:6px}
.ov-sub{font-size:.84rem;color:var(--muted);margin-bottom:26px}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:.76rem;font-weight:700;color:#aaa;margin-bottom:6px;letter-spacing:.5px;text-transform:uppercase}
.form-group input,.form-group select{width:100%;background:var(--bg);border:1.5px solid var(--border);color:#fff;border-radius:10px;padding:12px 14px;font-size:.88rem;outline:none;transition:border-color .2s;font-family:inherit}
.form-group input:focus,.form-group select:focus{border-color:var(--pink)}
.form-group input::placeholder{color:var(--muted)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.ov-btn{width:100%;background:var(--pink);color:#fff;border:none;cursor:pointer;padding:14px;border-radius:50px;font-size:.9rem;font-weight:800;letter-spacing:.5px;transition:background .2s;margin-top:6px}
.ov-btn:hover{background:#d40049}
.ov-link{display:block;text-align:center;margin-top:14px;font-size:.82rem;color:var(--muted)}
.ov-link a{color:var(--pink);text-decoration:none;font-weight:600}
.ov-link a:hover{text-decoration:underline}
.ov-divider{display:flex;align-items:center;gap:10px;margin:20px 0;color:var(--muted);font-size:.76rem}
.ov-divider::before,.ov-divider::after{content:'';flex:1;height:1px;background:var(--border)}
.ov-tabs{display:flex;background:var(--bg);border-radius:50px;padding:4px;margin-bottom:26px;border:1px solid var(--border)}
.ov-tab{flex:1;text-align:center;padding:9px;border-radius:50px;font-size:.8rem;font-weight:700;cursor:pointer;transition:all .2s;color:var(--muted)}
.ov-tab.active{background:var(--pink);color:#fff}
.error-msg{color:#ff4444;font-size:.78rem;margin-top:-10px;margin-bottom:10px;display:none}
.error-msg.show{display:block}
.success-msg{background:rgba(0,179,126,.1);border:1px solid rgba(0,179,126,.3);color:var(--green);border-radius:10px;padding:12px 16px;font-size:.84rem;margin-bottom:16px;display:none}
.success-msg.show{display:block}

/* WEBPAY CHECKOUT */
.checkout-steps{display:flex;gap:0;margin-bottom:28px;border-radius:50px;overflow:hidden;border:1px solid var(--border)}
.cs{flex:1;text-align:center;padding:10px 4px;font-size:.72rem;font-weight:700;color:var(--muted);background:var(--bg);border-right:1px solid var(--border);transition:all .3s;letter-spacing:.3px}
.cs:last-child{border-right:none}
.cs.done{background:rgba(0,179,126,.1);color:var(--green)}
.cs.active{background:rgba(255,0,92,.1);color:var(--pink)}
.order-items-mini{border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:18px}
.oi-row{display:flex;justify-content:space-between;align-items:center;padding:11px 16px;font-size:.82rem;border-bottom:1px solid var(--border)}
