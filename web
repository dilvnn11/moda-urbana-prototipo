// — Hash simple (FNV-1a 32bit) para no guardar contraseñas en texto plano —
function hashPass(str) {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 16777619) >>> 0;
  }
  return h.toString(16);
}

// — Validación de formato de email —
function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email);
}

// — Usuarios predeterminados (solo se crean si localStorage está vacío) —
const DEFAULT_USERS = [
  {id:1, name:'Admin', last:'Y2K', email:'admin@modaurbano.cl', passHash: hashPass('admin123'), role:'admin', date:'2024-01-15', orders:[]},
  {id:2, name:'Cliente', last:'Demo', email:'cliente@y2k.cl', passHash: hashPass('cliente123'), role:'cliente', date:'2025-03-20', orders:[]}
];

// — Carga y guardado en localStorage —
function loadUsers() {
  try {
    const stored = localStorage.getItem('mu_users');
    return stored ? JSON.parse(stored) : JSON.parse(JSON.stringify(DEFAULT_USERS));
  } catch(e) { return JSON.parse(JSON.stringify(DEFAULT_USERS)); }
}
function saveUsers() {
  try { localStorage.setItem('mu_users', JSON.stringify(users)); } catch(e) {}
}
function loadSession() {
  try {
    const s = localStorage.getItem('mu_session');
    if (!s) return null;
    const { id } = JSON.parse(s);
    return users.find(u => u.id === id) || null;
  } catch(e) { return null; }
}
function saveSession(user) {
  try {
    if (user) localStorage.setItem('mu_session', JSON.stringify({id: user.id}));
    else localStorage.removeItem('mu_session');
  } catch(e) {}
}

