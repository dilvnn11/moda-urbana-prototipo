// CART
// ══════════════════════════════════════
function addToCart() {
  if (!currentProduct) return;
  if (!selectedSize && currentProduct.sizes.length>1) {
    const el = document.getElementById('mSizes');
    el.style.outline='1.5px solid var(--pink)'; el.style.borderRadius='8px'; el.style.padding='6px';
    setTimeout(()=>{el.style.outline='';el.style.padding='';},1800);
    return;
  }
  const sz = selectedSize||currentProduct.sizes[0];
  const existing = cartItems.find(i=>i.id===currentProduct.id && i.size===sz);
  if (existing) existing.qty++;
  else cartItems.push({...currentProduct, size:sz, qty:1});
  closeModalDirect();
  updateCart();
  toggleCart();
}
function removeItem(id, size) {
  cartItems = cartItems.filter(i=>!(i.id===id && i.size===size));
  updateCart();
}
function changeQty(id, size, delta) {
  const item = cartItems.find(i=>i.id===id && i.size===size);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) cartItems = cartItems.filter(i=>!(i.id===id && i.size===size));
  updateCart();
}
function applyDiscount() {
  const code = document.getElementById('discountInput').value.trim().toUpperCase();
  const el = document.getElementById('discountMsg');
  if (DISCOUNT_CODES[code]) {
    discountCode = code; discountPct = DISCOUNT_CODES[code];
    el.className='discount-ok'; el.textContent=`✓ Código "${code}" aplicado: ${discountPct}% de descuento`;
    updateCart();
  } else {
    discountCode=''; discountPct=0;
    el.className='error-msg show'; el.textContent='Código inválido. Prueba: Y2K10, CYBER20 o DROP15';
    updateCart();
  }
}
function updateCart() {
  const count = cartItems.reduce((a,i)=>a+i.qty,0);
  const subtotal = cartItems.reduce((a,i)=>a+i.price*i.qty,0);
  const discAmt = Math.round(subtotal * discountPct / 100);
  const total = subtotal - discAmt;
  document.getElementById('cartCount').textContent = count;
  document.getElementById('cartItemLabel').textContent = count;
  document.getElementById('cartSubtotal').textContent = '$'+subtotal.toLocaleString('es-CL');
  document.getElementById('cartTotal').textContent = '$'+total.toLocaleString('es-CL');
  const dr = document.getElementById('discountRow');
  if (discAmt>0) {
    dr.style.display='flex';
    document.getElementById('discountLabel').textContent = `Descuento (${discountPct}%)`;
    document.getElementById('discountAmt').textContent = '-$'+discAmt.toLocaleString('es-CL');
  } else { dr.style.display='none'; }
  const body = document.getElementById('cartBody');
  if (!cartItems.length) {
    body.className='cart-empty-state';
    body.innerHTML='<span style="font-size:2.5rem">🛒</span><span>Tu carrito está vacío</span><button class="btn-w" style="font-size:.78rem;padding:10px 22px" onclick="toggleCart()">Seguir comprando</button>';
  } else {
    body.className='cart-items';
    body.innerHTML = cartItems.map(i=>`
      <div class="cart-item">
        <img class="ci-img" src="${i.img}" alt="${i.name}">
        <div class="ci-info">
          <div class="ci-name">${i.name}</div>
          <div class="ci-sz">Talla: ${i.size}</div>
          <div class="ci-bottom">
            <div class="ci-qty">
              <button onclick="changeQty(${i.id},'${i.size}',-1)">−</button>
              <span>${i.qty}</span>
              <button onclick="changeQty(${i.id},'${i.size}',1)">+</button>
            </div>
            <span class="ci-price">$${(i.price*i.qty).toLocaleString('es-CL')}</span>
            <button class="ci-rm" onclick="removeItem(${i.id},'${i.size}')">✕</button>
          </div>
        </div>
      </div>`).join('');
  }
}
function toggleCart() {
  document.getElementById('cartDrw').classList.toggle('open');
  document.getElementById('cartOv').classList.toggle('open');
  document.body.style.overflow = document.getElementById('cartDrw').classList.contains('open') ? 'hidden' : '';
